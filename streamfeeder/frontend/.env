# Edit this, or provide a .env.local, or... something like that...
#VITE_SF_DAV_ENDPOINT=https://nextcloud.example.org/remote.php/dav/files/username
#VITE_SF_DAV_USERNAME=username
#VITE_SF_DAV_PASSWORD=some-password

# A good option for testing is (requires rclone 1.73.2 or later for 'depth' in cors headers)
# `rclone serve webdav --user testu --pass testp ~/Pictures --allow-origin "*"`
VITE_SF_DAV_ENDPOINT=http://127.0.0.1:8080/
VITE_SF_DAV_USERNAME=testu
VITE_SF_DAV_PASSWORD=testp

